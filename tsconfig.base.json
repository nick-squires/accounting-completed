{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "strict": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@accounting-completed/domain": ["packages/domain/src/index.ts"],
      "@accounting-completed/theme/*": ["packages/theme/src/*"],
      "@accounting-completed/ui": ["packages/ui/src/index.ts"],
      "@accounting-completed/contracts": ["packages/contracts/src/index.ts"],
      "@accounting-completed/db": ["packages/db/src/index.ts"],
      "@accounting-completed/utils": ["packages/utils/src/index.ts"],
      "ui": ["packages/ui/src/index.ts"]
    }
  }
}
